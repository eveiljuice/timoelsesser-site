---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";
import { HERO_PHRASES } from "@/data/phrases";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

const projects = await getCollection("projects", ({ data }) => !data.draft);
const featuredProjects = projects
  .filter(p => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section
      id="hero"
      class="relative border-b border-border pt-10 pb-14 sm:pt-14 sm:pb-20"
    >
      <!-- status line -->
      <div
        class="mb-10 flex flex-wrap items-center gap-x-3 gap-y-1 text-[11px] font-medium tracking-[0.2em] text-foreground/55 uppercase"
        style="animation: var(--animate-fade-up);"
      >
        <span class="relative inline-flex size-2">
          <span
            class="absolute inline-flex size-full animate-ping rounded-full bg-accent opacity-70"
          ></span>
          <span class="relative inline-flex size-2 rounded-full bg-accent"
          ></span>
        </span>
        <span>online</span>
        <span class="text-border">/</span>
        <span class="text-foreground/70">shipping ai agents</span>
        <span class="ml-auto hidden text-foreground/40 sm:inline"
          >~/timoelsesser</span
        >
      </div>

      <div
        class="text-sm text-foreground/55"
        style="animation: var(--animate-fade-up); animation-delay: 60ms;"
      >
        <span class="text-accent">$</span> whoami
      </div>

      <h1
        class="mt-3 text-5xl leading-[0.95] font-semibold tracking-tight sm:mt-4 sm:text-7xl"
        style="animation: var(--animate-fade-up); animation-delay: 120ms;"
      >
        Timo
        <span class="italic text-accent">Elsesser</span>
      </h1>

      <p
        class="mt-4 flex items-baseline text-base text-foreground/80 sm:text-lg"
        style="animation: var(--animate-fade-up); animation-delay: 200ms;"
      >
        <span class="text-accent">&gt;&nbsp;</span>
        <span
          id="hero-tagline"
          data-phrases={JSON.stringify(HERO_PHRASES)}
          aria-live="polite"
        >{HERO_PHRASES[0]}</span>
        <span class="terminal-cursor" aria-hidden="true"></span>
      </p>

      <div
        class="mt-10 max-w-xl space-y-2 text-sm leading-relaxed text-foreground/75 sm:text-base"
        style="animation: var(--animate-fade-up); animation-delay: 280ms;"
      >
        <p class="text-foreground/50">
          <span class="text-accent">$</span> cat bio.md
        </p>
        <p>
          Building with AI. Writing along the way. Poke around
          <a href="/projects/" class="bracket-link">projects</a>
          or read the
          <a href="/posts/" class="bracket-link">blog</a>.
        </p>
      </div>

      <div
        class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-6"
        style="animation: var(--animate-fade-up); animation-delay: 360ms;"
      >
        {
          SOCIALS.length > 0 && (
            <div class="flex items-center gap-3">
              <span class="text-xs tracking-[0.2em] text-foreground/45 uppercase">
                find me
              </span>
              <Socials />
            </div>
          )
        }
        <a
          target="_blank"
          href="/rss.xml"
          class="ms-auto inline-flex items-center gap-1.5 text-xs tracking-[0.2em] text-foreground/45 uppercase hover:text-accent"
          aria-label="RSS feed"
          title="RSS"
        >
          <IconRss width={14} height={14} class="stroke-current stroke-[2]" />
          rss
        </a>
      </div>
    </section>

    {
      featuredProjects.length > 0 && (
        <section
          id="projects"
          class:list={[
            "pt-14 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <div class="section-marker mb-6">
            <span>// projects</span>
          </div>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            {featuredProjects.map(project => (
              <ProjectCard project={project} />
            ))}
          </div>
          <div class="mt-8 text-end">
            <LinkButton
              href="/projects/"
              class="text-sm text-foreground/70 hover:text-accent"
            >
              all projects
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
          </div>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-14 pb-6">
          <div class="section-marker mb-6">
            <span>// recent posts</span>
          </div>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <div class="my-10 text-center">
          <LinkButton
            href="/posts/"
            class="text-sm text-foreground/70 hover:text-accent"
          >
            all posts
            <IconArrowRight class="inline-block rtl:-rotate-180" />
          </LinkButton>
        </div>
      )
    }
  </main>
  <Footer />
</Layout>

<script>
  type TypewriterState = { timer: number | null };
  const state: TypewriterState = { timer: null };

  function startTypewriter() {
    if (state.timer !== null) {
      clearTimeout(state.timer);
      state.timer = null;
    }

    const el = document.getElementById("hero-tagline");
    if (!el) return;

    let phrases: string[] = [];
    try {
      phrases = JSON.parse(el.dataset.phrases || "[]");
    } catch {
      return;
    }
    if (phrases.length === 0) return;

    // Respect users who don't want motion — just show the first phrase.
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      el.textContent = phrases[0];
      return;
    }

    let phraseIdx = 0;
    let charIdx = phrases[0].length; // start with first phrase fully printed
    let deleting = true; // immediately start erasing the SSR-rendered phrase
    let holdUntilFirstErase = true;

    const TYPE_DELAY = 70;
    const ERASE_DELAY = 32;
    const PAUSE_AFTER_FULL = 1800;
    const PAUSE_BEFORE_NEXT = 350;

    function schedule(ms: number) {
      state.timer = window.setTimeout(tick, ms);
    }

    function tick() {
      const current = phrases[phraseIdx];

      if (holdUntilFirstErase) {
        holdUntilFirstErase = false;
        schedule(PAUSE_AFTER_FULL);
        return;
      }

      if (deleting) {
        charIdx = Math.max(0, charIdx - 1);
        el!.textContent = current.slice(0, charIdx);
        if (charIdx === 0) {
          deleting = false;
          phraseIdx = (phraseIdx + 1) % phrases.length;
          schedule(PAUSE_BEFORE_NEXT);
          return;
        }
        schedule(ERASE_DELAY);
      } else {
        charIdx = Math.min(current.length, charIdx + 1);
        el!.textContent = current.slice(0, charIdx);
        if (charIdx === current.length) {
          deleting = true;
          schedule(PAUSE_AFTER_FULL);
          return;
        }
        schedule(TYPE_DELAY + Math.random() * 40);
      }
    }

    tick();
  }

  function onPageLoad() {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
      startTypewriter();
    }
  }

  function stopTypewriter() {
    if (state.timer !== null) {
      clearTimeout(state.timer);
      state.timer = null;
    }
  }

  document.addEventListener("astro:page-load", onPageLoad);
  document.addEventListener("astro:before-swap", stopTypewriter);
</script>
