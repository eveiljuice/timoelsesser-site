---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import { SITE } from "@/config";
---

<Layout title={`404 Not Found | ${SITE.title}`}>
  <Header />

  <main
    id="main-content"
    class="app-layout flex flex-1 items-center justify-center"
  >
    <div class="mb-14 flex flex-col items-center justify-center text-center">
      <div class="text-xs tracking-[0.3em] text-foreground/40 uppercase">
        error
      </div>
      <h1 class="mt-2 text-8xl font-bold text-accent sm:text-9xl">404</h1>
      <span aria-hidden="true" class="mt-2 text-foreground/60"
        >¯\_(ツ)_/¯</span
      >
      <p class="mt-6 text-lg sm:text-xl">
        <span class="text-accent">$</span> page not found
      </p>
      <LinkButton
        href="/"
        class="mt-8 bracket-link text-sm tracking-wider uppercase"
      >
        back to home
      </LinkButton>
    </div>
  </main>

  <Footer />
</Layout>
