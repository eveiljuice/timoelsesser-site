---
import type { HTMLAttributes } from "astro/types";
import Socials from "./Socials.astro";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div
    class:list={[
      "py-6 sm:py-5",
      "border-t border-border",
      "flex flex-col items-center gap-3 sm:flex-row-reverse sm:justify-between",
    ]}
  >
    <Socials />
    <div
      class="flex flex-col items-center gap-x-2 gap-y-1 text-xs tracking-[0.15em] text-foreground/55 uppercase sm:flex-row"
    >
      <span>&copy; {currentYear} Timo Elsesser</span>
      <span aria-hidden="true" class="hidden text-border sm:inline">//</span>
      <span>built in the terminal</span>
    </div>
  </div>
</footer>
